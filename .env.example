# Copy this file to ".env" and fill in the values. Never commit .env.

# ── Discord ────────────────────────────────────────────────
# From https://discord.com/developers/applications  ->  your app  ->  Bot  ->  Reset Token
DISCORD_TOKEN=

# Optional: your Discord user ID (right-click yourself -> Copy User ID with Developer Mode on).
# Used for owner-only admin commands.
OWNER_ID=

# Optional but recommended for testing: your server (guild) ID.
# When set, slash commands sync to THIS server instantly. Leave blank for a global
# sync, which can take up to ~1 hour to appear. Right-click your server icon ->
# Copy Server ID (needs Developer Mode on).
GUILD_ID=

# ── clist.by (contest aggregator) ─────────────────────────
# Register at https://clist.by/ , then get your key at https://clist.by/api/v4/doc/
# The API user is your clist username; the key is the long token shown on that page.
CLIST_USERNAME=
CLIST_API_KEY=

# ── Google Drive study index (optional) ──────────────────
# Without a key the bot scrapes public folder pages, which only sees the first
# ~50 items per folder. For complete indexing, create a free API key at
# https://console.cloud.google.com/ (enable the Google Drive API) and paste it:
GOOGLE_API_KEY=

# ── Behaviour ─────────────────────────────────────────────
# Comma-separated lead times (in minutes) before a contest to send reminders.
REMINDER_LEAD_MINUTES=15
# How often the scheduler refreshes the contest cache, in minutes.
REFRESH_INTERVAL_MINUTES=30
# Hour (0-23) and IANA timezone for optional NITC bulletin digests.
BULLETIN_DIGEST_HOUR=8
BULLETIN_TIMEZONE=Asia/Kolkata
# Path to the SQLite database file.
DB_PATH=data/bot.db
